                                        <path d='M4 18V6a2 2 0 012-2h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2z' />
                                        <path d='M7 14l3-3 2 2 3-3 2 2' />
                                    </svg>
                                </div>
                                <div class="p3" aria-hidden="true">
                                    <svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' stroke-width='2' stroke='currentColor' fill='none' stroke-linecap='round' stroke-linejoin='round'>
                                        <path d='M0 0h24v24H0z' stroke='none' />
                                        <circle cx='12' cy='5' r='2' />
                                        <circle cx='5' cy='19' r='2' />
                                        <circle cx='19' cy='19' r='2' />
                                        <circle cx='12' cy='14' r='3' />
                                        <path d='M12 7v4M6.7 17.8l2.8-2M17.3 17.8l-2.8-2' />
                                    </svg>
